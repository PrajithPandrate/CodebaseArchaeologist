# Database
DATABASE_URL=postgresql+asyncpg://archaeologist:archaeologist_secret@localhost:5432/archaeologist_db
DATABASE_URL_SYNC=postgresql://archaeologist:archaeologist_secret@localhost:5432/archaeologist_db

# Redis
REDIS_URL=redis://localhost:6379/0

# App
SECRET_KEY=change_this_in_production
REPOS_DIR=./repos
DEBUG=true

# GitHub (optional - increases rate limits)
GITHUB_TOKEN=

# LLM Provider: openai | anthropic | none
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Embedding model: openai | anthropic | none (falls back to keyword-only)
EMBEDDING_PROVIDER=anthropic
EMBEDDING_MODEL=voyage-code-2

# CORS
CORS_ORIGINS=http://localhost:3000
