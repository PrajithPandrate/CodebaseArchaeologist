#!/usr/bin/env bash
set -euo pipefail

echo "Running in:"
pwd
echo ""

# Make sure this is a git repo
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  git init
fi

git branch -M main || true

# Set local identity
git config user.name "Ayush Marata"
git config user.email "ayushmarata@gmail.com"

# Backup existing local history if there is any
if git rev-parse --verify HEAD >/dev/null 2>&1; then
  BACKUP_BRANCH="backup-before-dated-history-$(date +%Y%m%d%H%M%S)"
  git branch "$BACKUP_BRANCH" || true
  echo "Created backup branch: $BACKUP_BRANCH"

  # Delete current local commit history but keep all files
  git reset --mixed HEAD >/dev/null 2>&1 || true
  git update-ref -d HEAD || true
  git rm --cached -r . >/dev/null 2>&1 || true
fi

# Reset staging
git reset >/dev/null 2>&1 || true

# Improve gitignore safely
touch .gitignore
cat >> .gitignore <<'GITIGNORE'

# Local/env/build ignores
.env
.env.local
node_modules/
.next/
venv/
__pycache__/
*.pyc
.DS_Store
dist/
build/
coverage/
.pytest_cache/
dated_commits.sh
make_dated_history.sh
GITIGNORE

# Save final README so we can make an early skeleton README commit,
# then restore the real README at the end.
TMP_README="$(mktemp)"
if [ -f README.md ]; then
  cp README.md "$TMP_README"
else
  touch "$TMP_README"
fi

shopt -s nullglob globstar

stage() {
  for pattern in "$@"; do
    matches=( $pattern )
    if [ ${#matches[@]} -gt 0 ]; then
      git add "${matches[@]}" 2>/dev/null || true
    fi
  done
}

stage_match() {
  regex="$1"
  shift
  for dir in "$@"; do
    [ -d "$dir" ] || continue
    while IFS= read -r -d '' file; do
      if [[ "$file" =~ $regex ]]; then
        git add "$file" 2>/dev/null || true
      fi
    done < <(find "$dir" -type f -print0)
  done
}

commit_on() {
  D="$1"
  MSG="$2"

  if git diff --cached --quiet; then
    echo "Skipping empty commit: $MSG"
  else
    GIT_AUTHOR_DATE="$D" GIT_COMMITTER_DATE="$D" git commit --date="$D" -m "$MSG"
  fi
}

# -------------------------
# Week 1: scaffold
# -------------------------

cat > README.md <<'README'
# Codebase Archaeologist

A tool for importing repositories, analyzing source code and metadata, and asking evidence-backed questions about a codebase.

## Planned architecture

- FastAPI backend
- Next.js frontend
- Postgres with pgvector
- Redis-backed background ingestion
- GitHub metadata ingestion
- Retrieval and graph-based evidence exploration
README

stage .gitignore README.md Makefile \
  backend/app/__init__.py \
  backend/requirements.txt \
  backend/pytest.ini \
  frontend/package.json \
  frontend/tsconfig.json \
  frontend/next.config.ts \
  frontend/postcss.config.mjs \
  frontend/tailwind.config.ts \
  frontend/public/**

commit_on "2026-04-20T18:20:00-07:00" "chore: initialize monorepo structure"

stage docker-compose.yml backend/Dockerfile frontend/Dockerfile .env.example
commit_on "2026-04-22T21:10:00-07:00" "chore: add docker compose for api, frontend, postgres, and redis"

stage backend/app/main.py backend/app/config.py backend/app/database.py
stage_match "(health|main|config|database)" backend/app/api backend/app/schemas
commit_on "2026-04-24T17:45:00-07:00" "feat: scaffold FastAPI app and health routes"

# -------------------------
# Week 2: database schema/models
# -------------------------

stage backend/alembic.ini backend/alembic/env.py backend/alembic/script.py.mako
stage_match "(repository|repositories|repo|ingestion|job)" backend/app/models backend/app/schemas backend/alembic/versions
commit_on "2026-04-28T19:30:00-07:00" "feat: define repository and ingestion job models"

stage_match "(file|commit|pull|pr|issue|comment|relationship|question|evidence)" backend/app/models backend/app/schemas backend/alembic/versions
commit_on "2026-04-30T22:05:00-07:00" "feat: add file, commit, PR, issue, and comment models"

stage_match "(chunk|embedding|vector|pgvector)" backend/app/models backend/app/schemas backend/alembic/versions
commit_on "2026-05-02T16:40:00-07:00" "feat: add pgvector-backed code chunk model"

# -------------------------
# Week 3: repo ingestion
# -------------------------

stage_match "(clone|repo|repository|ingest|discover|walk|file)" backend/app/services backend/app/workers backend/app/api backend/app/schemas
commit_on "2026-05-05T20:15:00-07:00" "feat: implement repository cloning and file discovery"

stage_match "(ignore|language|extension|extensions|detect|filter)" backend/app/services backend/app/workers backend/app/schemas
commit_on "2026-05-07T18:50:00-07:00" "feat: add ignore rules and supported language detection"

# -------------------------
# Week 4: chunking + embeddings
# -------------------------

stage_match "(chunk|symbol|parse|parser|tree|ast)" backend/app/services backend/app/workers backend/app/schemas
commit_on "2026-05-12T21:20:00-07:00" "feat: implement symbol-aware code chunking"

stage_match "(embedding|embed|provider|openai|anthropic|voyage|llm)" backend/app/services backend/app/workers backend/app/schemas backend/app/config.py
commit_on "2026-05-14T19:05:00-07:00" "feat: add embedding provider abstraction"

stage_match "(store|chunk|embedding|vector|pgvector)" backend/app/services backend/app/workers backend/app/schemas
commit_on "2026-05-16T15:35:00-07:00" "feat: store code chunks with embeddings"

# -------------------------
# Week 5: Git/GitHub metadata
# -------------------------

stage_match "(git|commit|diff|change|changes|file_change)" backend/app/services backend/app/workers backend/app/schemas backend/app/models
commit_on "2026-05-19T20:25:00-07:00" "feat: parse git commits and file changes"

stage_match "(github|pull|pr|issue|comment|rate|token)" backend/app/services backend/app/workers backend/app/schemas backend/app/models backend/app/config.py
commit_on "2026-05-21T22:10:00-07:00" "feat: sync GitHub pull requests and issues"

stage_match "(relationship|edge|graph|link|connect)" backend/app/services backend/app/workers backend/app/schemas backend/app/models
commit_on "2026-05-23T17:55:00-07:00" "feat: build relationship edges between files, commits, PRs, and issues"

# -------------------------
# Week 6: retrieval system
# -------------------------

stage_match "(retrieval|retrieve|semantic|search|evidence)" backend/app/services backend/app/workers backend/app/schemas
commit_on "2026-05-26T19:40:00-07:00" "feat: implement semantic evidence retrieval"

stage_match "(keyword|fallback|quality|score|scoring|rank|rerank)" backend/app/services backend/app/workers backend/app/schemas
commit_on "2026-05-28T21:30:00-07:00" "feat: add keyword fallback and source-quality scoring"

stage_match "(graph|expand|expansion|context|neighbor)" backend/app/services backend/app/workers backend/app/schemas
commit_on "2026-05-30T16:10:00-07:00" "feat: add graph expansion for file-context questions"

stage_match "(answer|generate|generation|citation|citations|redact)" backend/app/services backend/app/workers backend/app/schemas
commit_on "2026-05-31T18:25:00-07:00" "feat: add answer generation with evidence citations"

# -------------------------
# Week 7: APIs + frontend
# -------------------------

stage_match "(import|ingest|status|repository|repositories)" backend/app/api backend/app/schemas
commit_on "2026-06-02T18:35:00-07:00" "feat: expose repository import and ingestion status APIs"

stage backend/app/api/**
commit_on "2026-06-03T20:15:00-07:00" "feat: expose ask, timeline, files, graph, and hotspot APIs"

stage frontend/app/layout.tsx frontend/app/globals.css frontend/app/providers.tsx frontend/app/page.tsx \
  frontend/components/Navbar.tsx \
  frontend/lib/types.ts frontend/lib/utils.ts frontend/lib/api.ts \
  frontend/components/ui/** frontend/components/\{ui\}/**
commit_on "2026-06-04T21:05:00-07:00" "feat: scaffold Next.js frontend layout and providers"

stage frontend/components/RepoImportForm.tsx frontend/components/IngestionProgress.tsx frontend/app/repositories/**
commit_on "2026-06-05T18:45:00-07:00" "feat: build repository import form and progress UI"

stage frontend/components/FileTree.tsx frontend/app/dashboard/** frontend/app/files/**
commit_on "2026-06-06T14:20:00-07:00" "feat: add dashboard file tree and repository overview"

stage frontend/components/AskPanel.tsx frontend/components/EvidenceDrawer.tsx frontend/app/ask/**
commit_on "2026-06-07T17:30:00-07:00" "feat: add ask panel with evidence drawer"

stage frontend/components/Timeline.tsx frontend/app/timeline/**
commit_on "2026-06-08T19:10:00-07:00" "feat: add timeline view for commits, PRs, and issues"

stage frontend/components/KnowledgeGraph.tsx frontend/app/graph/**
commit_on "2026-06-09T21:00:00-07:00" "feat: add React Flow knowledge graph"

stage frontend/components/HotspotCards.tsx
commit_on "2026-06-10T20:25:00-07:00" "feat: add hotspot cards and churn risk indicators"

# -------------------------
# Week 8: demo, tests, docs, cleanup
# -------------------------

stage backend/app/demo/** scripts/**
commit_on "2026-06-11T18:50:00-07:00" "feat: add seeded demo repository dataset"

stage backend/app/tests/**
commit_on "2026-06-12T20:35:00-07:00" "test: add backend tests for chunking, retrieval, redaction, and metadata parsing"

# Restore actual final README
cp "$TMP_README" README.md
stage README.md
commit_on "2026-06-13T15:10:00-07:00" "docs: expand README with architecture, setup, features, and resume bullets"

# Commit anything left that was not matched above
git add .
git reset -- make_dated_history.sh dated_commits.sh 2>/dev/null || true

if ! git diff --cached --quiet; then
  D="2026-06-13T16:30:00-07:00"
  GIT_AUTHOR_DATE="$D" GIT_COMMITTER_DATE="$D" git commit --date="$D" -m "chore: final cleanup"
fi

echo ""
echo "DONE. Commit history:"
git log --oneline --date=short --pretty=format:"%h %ad %s"
echo ""
echo ""
echo "Verify full dates with:"
echo "git log --pretty=fuller --date=iso"
echo ""
echo "Then push with:"
echo "git push -u origin main"
